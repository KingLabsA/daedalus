{
  "name": "hermes-vscode",
  "displayName": "Hermes — Deep Mind Coding Assistant",
  "description": "Chat with your local Hermes agent: streaming answers, native inline diffs for every agent edit, auto-routing across local models.",
  "version": "0.1.0",
  "publisher": "fableforge",
  "license": "MIT",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Chat", "Programming Languages"],
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "hermes", "title": "Hermes", "icon": "$(hubot)" }
      ]
    },
    "views": {
      "hermes": [
        { "type": "webview", "id": "hermes.chat", "name": "Chat" }
      ]
    },
    "commands": [
      { "command": "hermes.ask", "title": "Hermes: Ask" },
      { "command": "hermes.askAboutFile", "title": "Hermes: Ask About Current File" },
      { "command": "hermes.cancel", "title": "Hermes: Cancel Current Run" },
      { "command": "hermes.reconnect", "title": "Hermes: Reconnect" }
    ],
    "configuration": {
      "title": "Hermes",
      "properties": {
        "hermes.host": {
          "type": "string",
          "default": "ws://127.0.0.1:8765",
          "description": "Hermes agent WebSocket URL (start with: hermes ws)"
        },
        "hermes.token": {
          "type": "string",
          "default": "",
          "description": "WS auth token (only needed when HERMES_WS_TOKEN is set on the server)"
        }
      }
    }
  },
  "dependencies": {
    "ws": "^8.17.0"
  }
}
