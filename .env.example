# ─── Hermes-Ultimate Configuration ──────────────────────────

# Default provider & model
LLM_PROVIDER=openai
MODEL_NAME=gpt-4o-mini

# ─── Provider API Keys ──────────────────────────────────────
# Only need the key(s) for your chosen provider(s)

# OpenAI-compatible (most providers)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OPENROUTER_API_KEY=sk-or-your-openrouter-key
GROQ_API_KEY=gsk_your-groq-key
XAI_API_KEY=your-xai-grok-key
DEEPSEEK_API_KEY=sk-your-deepseek-key
ZHIPU_API_KEY=your-zhipu-glm-key
MOONSHOT_API_KEY=sk-your-moonshot-kimi-key
MISTRAL_API_KEY=your-mistral-key
TOGETHER_API_KEY=your-together-key
FIREWORKS_API_KEY=your-fireworks-key
PERPLEXITY_API_KEY=pplx-your-perplexity-key
NOVITA_API_KEY=your-novita-key
GOOGLE_API_KEY=AIza-your-google-gemini-key
COHERE_API_KEY=your-cohere-key

# Local — no key needed
# OLLAMA_HOST=http://localhost:11434

# ─── WebSocket Server ───────────────────────────────────────
WS_HOST=127.0.0.1
WS_PORT=8765

# ─── Storage ────────────────────────────────────────────────
DB_FILE=hermes_ultimate.db
SKILLS_DIR=.hermes/skills
PLUGINS_DIR=plugins

# ─── Misc ───────────────────────────────────────────────────
# MAX_MESSAGES=30
# PLUGIN_REGISTRY_URL=https://hermes-plugins.fake
